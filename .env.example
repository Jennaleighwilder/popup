# Popup Environment Variables
# Copy to .env.local and fill in your values

# Supabase (required for auth)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase Service Role (server-side only, for admin operations)
# Get from Supabase Dashboard > Settings > API
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe (for Phase 7+)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend (for Phase 8+ confirmation emails)
RESEND_API_KEY=re_...

# OpenAI (for Phase 5 AI create flow)
OPENAI_API_KEY=sk-...

# App URL (for Supabase OAuth redirect)
# Add to Supabase Auth > URL Configuration > Redirect URLs:
# - http://localhost:3000/auth/callback (local dev)
# - https://yourdomain.com/auth/callback (production)
NEXT_PUBLIC_APP_URL=http://localhost:3000
